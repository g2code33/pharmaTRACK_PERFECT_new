{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "bundle": {
    "active": true,
    "category": "Education",
    "copyright": "",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "productName": "PharmaTRACK",
  "mainBinaryName": "PharmaTRACK",
  "version": "1.0.0",
  "identifier": "com.pharmatrack.app",
  "plugins": {},
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "fullscreen": false,
        "height": 900,
        "resizable": true,
        "title": "PharmaTRACK",
        "width": 1400,
        "minWidth": 1000,
        "minHeight": 700,
        "useHttpsScheme": true
      }
    ]
  }
}